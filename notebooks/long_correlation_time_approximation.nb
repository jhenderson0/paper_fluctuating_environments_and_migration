    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "m"}], "*", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"G1", "[", "t_", "]"}], " ", "=", " ", 
