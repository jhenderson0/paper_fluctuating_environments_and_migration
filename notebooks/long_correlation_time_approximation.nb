       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "1"}], ")"}]}], ")"}]}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "m"}], "*", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"S", "[", "t_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"m", "*", "nu", "*", "t"}], " ", "-", " ", 
