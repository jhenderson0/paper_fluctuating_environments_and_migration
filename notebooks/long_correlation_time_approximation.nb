    RowBox[{"t", "^", 
     RowBox[{"(", 
      RowBox[{"nu", " ", "-", 
       RowBox[{"(", 
        RowBox[{"1", "+", "1"}], ")"}]}], ")"}]}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "m"}], "*", "t"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Gneg1", "[", "t_", "]"}], " ", "=", "  ", 
