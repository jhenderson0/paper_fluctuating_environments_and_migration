         "0"}], ",", "t"}], "]"}]}], ",", " ", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{"d", " ", "<", " ", 
        RowBox[{"1", "+", "z"}]}], "}"}]}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}], "\[IndentingNewLine]", 
