Cell[CellGroupData[{
Cell["Small noise saddle point approximation for zeta", "Title",
 CellChangeTimes->{{3.9804519113831053`*^9, 
  3.980451924517065*^9}},ExpressionUUID->"e4b99239-2472-43d6-b2ef-\
ff00060fe4a2"],

Cell[CellGroupData[{

Cell["Define key functions", "Section",
 CellChangeTimes->{{3.980448353054842*^9, 3.980448358695249*^9}, {
  3.9804493299953136`*^9, 
  3.9804493423874283`*^9}},ExpressionUUID->"542606fc-9a65-44f0-9e1e-\
4f6ce6adb22e"],

Cell[CellGroupData[{

Cell["Phi and the g\[CloseCurlyQuote]s", "Subsection",
 CellChangeTimes->{{3.9804493511353817`*^9, 
  3.980449387758759*^9}},ExpressionUUID->"0fcc82ad-204d-40cf-a213-\
3e071671f159"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"$Assumptions", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"l", ">", "0"}], ",", " ", 
     RowBox[{"d", ">", "0"}], ",", 
     RowBox[{"t", ">", "0"}], ",", " ", 
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"l", ",", "d", ",", "z", ",", "t"}], "}"}], ",", "Reals"}], 
      "]"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g1", "[", "t_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", "t"}], " ", "*", " ", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{
       RowBox[{"1", "/", "l"}], " ", "*", " ", "t"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"g2", "[", "t_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{"t", "^", "2"}], ")"}]}], " ", "*", " ", 
    RowBox[{"(", 
     RowBox[{"1", " ", "+", " ", 
      RowBox[{
       RowBox[{"1", "/", "l"}], " ", "*", " ", "t"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"phi", "[", "t_", "]"}], " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "+", " ", "z"}], ")"}], 
     RowBox[{"Log", "[", "t", "]"}]}], " ", "-", " ", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", " ", "-", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", " ", "+", " ", "z"}], ")"}], "/", "l"}]}], ")"}], "*", 
     "t"}], "-", 
    RowBox[{
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"2", "*", "l"}], ")"}]}], " ", "*", " ", 
     RowBox[{"t", "^", "2"}]}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9804484542064238`*^9, 3.980448583900762*^9}, {
   3.9804486263640127`*^9, 3.9804486267210627`*^9}, 3.980448695757409*^9, {
   3.980448793863652*^9, 3.980448856825799*^9}, {3.980450615393053*^9, 
   3.9804506172045*^9}, 3.980457079480741*^9, {3.9804573857869596`*^9, 
   3.980457396313724*^9}, 3.98045786888691*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"93f58a60-9f35-4506-aa51-3e7a9241c50c"]
}, Open  ]],

