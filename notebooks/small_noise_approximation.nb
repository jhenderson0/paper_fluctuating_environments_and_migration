Cell[CellGroupData[{

Cell["\<\
Compute integrals to first order in D (dropping the prefactor)\
\>", "Section",
 CellChangeTimes->{{3.980449513847698*^9, 3.9804495306362743`*^9}, {
  3.980449573195773*^9, 
  3.980449578414226*^9}},ExpressionUUID->"c0fe6145-c127-4bdd-9fb7-\
c7de82d38fa0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"I1", " ", "=", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"g1", "[", "tstar", "]"}], " ", "+", " ", 
    RowBox[{"d", "*", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"d2g1", "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "2"}], "*", "d2phi"}], ")"}]}], " ", "+", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"d1g1", " ", "*", " ", "d3phi"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"2", " ", "*", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "d2phi"}], ")"}], "^", "2"}]}], ")"}]}], " ", "+", 
        " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"g1", "[", "tstar", "]"}], " ", "*", " ", "d4phi"}], ")"}],
          "/", 
         RowBox[{"(", 
          RowBox[{"8", " ", "*", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "d2phi"}], ")"}], "^", "2"}]}], ")"}]}], " ", "+", 
        " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"5", " ", "*", " ", 
           RowBox[{"g1", "[", "tstar", "]"}], " ", "*", " ", 
           RowBox[{
            RowBox[{"(", "d3phi", ")"}], "^", "2"}]}], " ", ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"24", " ", "*", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"-", "d2phi"}], ")"}], "^", "3"}]}], ")"}]}]}], ")"}], 
      "]"}]}]}], ")"}]}]], "Input",
